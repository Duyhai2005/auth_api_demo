# Application
APP_NAME=Auth API Demo
DEBUG=false

# JWT
JWT_SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

MYSQL_DATABASE = xxx
MYSQL_USER = xxx
MYSQL_PASSWORD = xxx
MYSQL_ROOT_PASSWORD = xxx

# SQLite local example:
# DATABASE_URL="sqlite:///./blog.db"

# MySQL example. URL-encode special characters in the password, e.g. @ -> %40.
DATABASE_URL="mysql+pymysql://user:password@localhost:3306/database_name"
